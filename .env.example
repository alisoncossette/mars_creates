# Copy to .env and fill in. Anything blank => that piece runs in mock/skip mode.

# --- X / Twitter (posting) ---
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# --- Magnific (image generation) — api.magnific.com ---
MAGNIFIC_API_KEY=
MAGNIFIC_BASE_URL=https://api.magnific.com

# --- Claude (captions) ---
ANTHROPIC_API_KEY=
MARS_LLM_MODEL=claude-opus-4-8

# --- Post styling ---
MARS_ALWAYS_TAG=@hackersquadsf,@Magnific_AI   # tagged on every post
MARS_DEBUT_NOTE=🤖 My very first post — written and posted all by myself!

# --- Event context (optional; else Mars asks the operator at kickoff) ---
MARS_EVENT_NAME=
MARS_EVENT_SPONSORS=
