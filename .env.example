# Copy to .env and fill in. Anything blank => that tool runs in MOCK mode.

# --- Interview brain (Claude) ---
ANTHROPIC_API_KEY=
MARS_LLM_MODEL=claude-opus-4-8

# --- Voice (onboard mic + speaker) ---
ELEVENLABS_API_KEY=        # TTS (or use OPENAI_API_KEY)
DEEPGRAM_API_KEY=          # STT (or use OPENAI_API_KEY / local whisper)
OPENAI_API_KEY=            # optional fallback for TTS+STT

# --- Magnific (api.magnific.com) ---
MAGNIFIC_API_KEY=          # Magnific Creative Upscaler
MAGNIFIC_BASE_URL=https://api.magnific.com
MARS_MAGNIFIC_SCALE=2      # upscale factor

# --- Akamai Cloud = Linode Object Storage (S3), fronted by Akamai CDN ---
LINODE_S3_ENDPOINT=        # e.g. https://us-east-1.linodeobjects.com
LINODE_S3_REGION=us-east-1
LINODE_S3_BUCKET=          # your bucket name
LINODE_S3_ACCESS_KEY=
LINODE_S3_SECRET_KEY=
AKAMAI_CDN_BASE_URL=       # optional custom Akamai domain in front of the bucket
# live stream (only if MARS_LIVE=1)
AKAMAI_RTMP_INGEST_URL=    # rtmp://... ingest endpoint
AKAMAI_STREAM_KEY=

# --- Publishing targets ---
MARS_PUBLISH_GALLERY=1
MARS_PUBLISH_X=1
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# --- Run flags ---
MARS_LIVE=0                # 1 = also push live RTMP to Akamai
MARS_MAX_QUESTIONS=4

# --- Event context (Mars asks at kickoff if these are blank) ---
MARS_EVENT_NAME=
MARS_EVENT_LOCATION=
MARS_EVENT_VIBE=
MARS_EVENT_SPONSORS=       # comma-separated, e.g. "Akamai,Magnific,Anthropic"
